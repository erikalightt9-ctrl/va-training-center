generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EnrollmentStatus {
  PENDING
  PAYMENT_SUBMITTED
  PAYMENT_VERIFIED
  EMAIL_VERIFIED
  APPROVED
  REJECTED
  ENROLLED
}

enum EmploymentStatus {
  EMPLOYED_FULL_TIME
  EMPLOYED_PART_TIME
  SELF_EMPLOYED
  UNEMPLOYED
  STUDENT
  FREELANCER
}

enum ToolFamiliarity {
  QUICKBOOKS
  CRM
  EHR
  MICROSOFT_OFFICE
  GOOGLE_WORKSPACE
  SLACK
  ZOOM
  TRELLO
  ASANA
  SALESFORCE
  HUBSPOT
  OTHER
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

enum SubmissionStatus {
  PENDING
  GRADED
  RETURNED
}

enum PaymentStatus {
  PENDING_PAYMENT
  PAID
  FAILED
  REFUNDED
}

enum EventType {
  ANNOUNCEMENT
  DEADLINE
  ORIENTATION
  HOLIDAY
  CUSTOM
}

enum BadgeType {
  FIRST_LESSON
  QUIZ_MASTER
  COURSE_COMPLETER
  TOP_CONTRIBUTOR
  ASSIGNMENT_STAR
  FORUM_STARTER
}

enum StudentPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum SubscriptionPlan {
  MONTHLY
  QUARTERLY
  LIFETIME
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ScheduleStatus {
  OPEN
  CLOSED
  FULL
  COMPLETED
}

enum TrainerTier {
  BASIC
  PROFESSIONAL
  PREMIUM
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
}

enum CourseTier {
  BASIC
  PROFESSIONAL
  ADVANCED
}

model Course {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  description   String       @db.Text
  durationWeeks Int
  price         Decimal      @db.Decimal(10, 2)
  priceBasic        Decimal  @default(1500) @db.Decimal(10, 2)
  priceProfessional Decimal  @default(3500) @db.Decimal(10, 2)
  priceAdvanced     Decimal  @default(5500) @db.Decimal(10, 2)
  currency      String       @default("PHP")
  outcomes      String[]
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  enrollments     Enrollment[]
  lessons         Lesson[]
  quizzes         Quiz[]
  certificates    Certificate[]
  threads         ForumThread[]
  assignments     Assignment[]
  calendarEvents  CalendarEvent[]
  schedules       Schedule[]
  trainers        CourseTrainer[]
  resources       CourseResource[]

  @@map("courses")
}

model Enrollment {
  id                    String            @id @default(cuid())
  status                EnrollmentStatus  @default(PENDING)
  paymentStatus         PaymentStatus     @default(PENDING_PAYMENT)
  fullName              String
  dateOfBirth           DateTime          @db.Date
  email                 String
  contactNumber         String
  address               String            @db.Text
  educationalBackground String            @db.Text
  workExperience        String            @db.Text
  employmentStatus      EmploymentStatus
  technicalSkills       String[]
  toolsFamiliarity      ToolFamiliarity[]
  whyEnroll             String            @db.Text
  courseId              String
  course                Course            @relation(fields: [courseId], references: [id])
  trainerId             String?
  trainer               Trainer?          @relation(fields: [trainerId], references: [id])
  courseTier            CourseTier        @default(BASIC)
  trainerTier           TrainerTier?
  baseProgramPrice      Decimal?          @db.Decimal(10, 2)
  trainerUpgradeFee     Decimal?          @db.Decimal(10, 2)
  scheduleId            String?
  schedule              Schedule?         @relation(fields: [scheduleId], references: [id])
  ipAddress             String?
  emailConfirmedAt         DateTime?
  emailVerificationToken   String?           @unique
  emailTokenExpiresAt      DateTime?
  activationToken          String?           @unique
  activationTokenExpiresAt DateTime?
  statusUpdatedAt          DateTime?
  statusUpdatedBy          String?
  referenceCode            String?           @unique
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  organizationId           String?
  organization             Organization? @relation(fields: [organizationId], references: [id])
  student                  Student?
  payments                 Payment[]
  waitlistEntries          Waitlist[]

  @@index([status])
  @@index([courseId])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([email])
  @@index([trainerId])
  @@index([scheduleId])
  @@index([referenceCode])
  @@index([organizationId])
  @@map("enrollments")
}

model Payment {
  id              String        @id @default(cuid())
  enrollmentId    String
  amount          Decimal       @db.Decimal(10, 2)
  method          String
  status          PaymentStatus @default(PENDING_PAYMENT)
  proofFilePath   String?
  proofFileName   String?
  referenceNumber String?
  notes           String?       @db.Text
  verifiedBy      String?
  verifiedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  enrollment      Enrollment    @relation(fields: [enrollmentId], references: [id])

  @@index([enrollmentId])
  @@index([status])
  @@map("payments")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model Student {
  id                 String               @id @default(cuid())
  enrollmentId       String               @unique
  email              String               @unique
  passwordHash       String
  name               String
  bio                String?              @db.Text
  avatarUrl          String?
  mustChangePassword Boolean              @default(true)
  batch              String?
  scheduleId         String?
  paymentStatus      StudentPaymentStatus @default(UNPAID)
  amountPaid         Decimal              @default(0) @db.Decimal(10, 2)
  accessGranted      Boolean              @default(false)
  accessExpiry       DateTime?
  notes              String?              @db.Text
  courseTier         CourseTier           @default(BASIC)
  trainerId          String?
  organizationId     String?
  portfolioPublic    Boolean              @default(false)
  createdAt          DateTime             @default(now())
  enrollment   Enrollment         @relation(fields: [enrollmentId], references: [id])
  schedule     Schedule?          @relation(fields: [scheduleId], references: [id])
  trainer      Trainer?           @relation(fields: [trainerId], references: [id])
  organization Organization?     @relation(fields: [organizationId], references: [id])
  completions  LessonCompletion[]
  attempts     QuizAttempt[]
  certificates Certificate[]
  threads      ForumThread[]
  posts        ForumPost[]
  submissions  Submission[]
  badges       StudentBadge[]
  points       PointTransaction[]
  attendance   AttendanceRecord[]
  careerScores   CareerReadinessScore[]
  simulations    SimulationSession[]
  interviews     InterviewSession[]
  jobMatches     JobMatch[]
  employerFeedback  EmployerFeedback[]
  mentorshipRequests MentorshipRequest[]
  emailPracticeSessions EmailPracticeSession[]
  jobApplications       JobApplication[]
  verifiedSkills        VerifiedSkill[]
  subscriptions         Subscription[]
  trainerRatings        TrainerRating[]
  sessionAttendances    SessionAttendance[]

  @@index([email])
  @@index([trainerId])
  @@index([paymentStatus])
  @@index([accessGranted])
  @@index([scheduleId])
  @@index([organizationId])
  @@map("students")
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String   @db.Text
  order       Int
  durationMin Int      @default(0)
  isPublished   Boolean  @default(false)
  isFreePreview Boolean  @default(false)
  tier          CourseTier @default(BASIC)
  videoUrl      String?
  createdAt     DateTime @default(now())
  course      Course             @relation(fields: [courseId], references: [id])
  completions LessonCompletion[]
  resources   CourseResource[]

  @@index([courseId, tier, order])
  @@map("lessons")
}

model LessonCompletion {
  id          String   @id @default(cuid())
  studentId   String
  lessonId    String
  completedAt DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([studentId, lessonId])
  @@map("lesson_completions")
}

model Quiz {
  id           String         @id @default(cuid())
  courseId     String
  title        String
  description  String?
  passingScore Int            @default(70)
  isPublished  Boolean        @default(false)
  createdAt    DateTime       @default(now())
  course       Course         @relation(fields: [courseId], references: [id])
  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@index([courseId])
  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  type          QuestionType
  question      String
  options       String[]
  correctAnswer String
  points        Int          @default(10)
  order         Int
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       QuizAnswer[]

  @@index([quizId, order])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String       @id @default(cuid())
  studentId   String
  quizId      String
  score       Int
  passed      Boolean
  completedAt DateTime     @default(now())
  student     Student      @relation(fields: [studentId], references: [id])
  quiz        Quiz         @relation(fields: [quizId], references: [id])
  answers     QuizAnswer[]

  @@index([studentId, quizId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id         String       @id @default(cuid())
  attemptId  String
  questionId String
  answer     String
  isCorrect  Boolean
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   QuizQuestion @relation(fields: [questionId], references: [id])

  @@map("quiz_answers")
}

model Certificate {
  id         String   @id @default(cuid())
  studentId  String
  courseId   String
  issuedAt   DateTime @default(now())
  certNumber String   @unique @default(cuid())
  student    Student  @relation(fields: [studentId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("certificates")
}

model ForumThread {
  id        String      @id @default(cuid())
  courseId  String?
  studentId String
  title     String
  createdAt DateTime    @default(now())
  course    Course?     @relation(fields: [courseId], references: [id])
  student   Student     @relation(fields: [studentId], references: [id])
  posts     ForumPost[]

  @@index([courseId])
  @@map("forum_threads")
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  studentId String
  content   String      @db.Text
  parentId  String?
  createdAt DateTime    @default(now())
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  student   Student     @relation(fields: [studentId], references: [id])
  parent    ForumPost?  @relation("Replies", fields: [parentId], references: [id])
  replies   ForumPost[] @relation("Replies")

  @@index([threadId])
  @@map("forum_posts")
}

model Assignment {
  id           String       @id @default(cuid())
  courseId     String
  title        String
  instructions String       @db.Text
  dueDate      DateTime?
  maxPoints    Int          @default(100)
  isPublished  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  course       Course       @relation(fields: [courseId], references: [id])
  submissions  Submission[]

  @@index([courseId])
  @@map("assignments")
}

model Submission {
  id              String           @id @default(cuid())
  assignmentId    String
  studentId       String
  filePath        String
  fileName        String
  fileSize        Int
  status          SubmissionStatus @default(PENDING)
  grade           Int?
  feedback        String?          @db.Text
  aiEvaluation    Json?
  aiEvaluatedAt   DateTime?
  submittedAt     DateTime         @default(now())
  gradedAt        DateTime?
  assignment      Assignment       @relation(fields: [assignmentId], references: [id])
  student         Student          @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@map("submissions")
}

model Badge {
  id          String        @id @default(cuid())
  type        BadgeType     @unique
  name        String
  description String
  icon        String
  students    StudentBadge[]

  @@map("badges")
}

model StudentBadge {
  id        String   @id @default(cuid())
  studentId String
  badgeId   String
  earnedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([studentId, badgeId])
  @@map("student_badges")
}

model PointTransaction {
  id        String   @id @default(cuid())
  studentId String
  points    Int
  reason    String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("point_transactions")
}

model AttendanceRecord {
  id        String    @id @default(cuid())
  studentId String
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  createdAt DateTime  @default(now())
  student   Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([clockIn])
  @@map("attendance_records")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model RateLimitAttempt {
  id        String   @id @default(cuid())
  ip        String
  endpoint  String
  createdAt DateTime @default(now())

  @@index([ip, endpoint, createdAt])
  @@map("rate_limit_attempts")
}

model Schedule {
  id                   String         @id @default(cuid())
  name                 String
  courseId              String
  trainerId            String?
  startDate            DateTime       @db.Date
  endDate              DateTime       @db.Date
  daysOfWeek           Int[]
  startTime            String
  endTime              String
  maxCapacity          Int            @default(25)
  enrollmentCutOffDays Int            @default(2)
  status               ScheduleStatus @default(OPEN)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  course               Course         @relation(fields: [courseId], references: [id])
  trainer              Trainer?       @relation(fields: [trainerId], references: [id])
  students             Student[]
  enrollments          Enrollment[]
  waitlist             Waitlist[]
  sessionAttendances   SessionAttendance[]

  @@index([courseId])
  @@index([trainerId])
  @@index([status])
  @@index([startDate])
  @@map("schedules")
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  date        DateTime  @db.Date
  endDate     DateTime? @db.Date
  type        EventType @default(CUSTOM)
  courseId     String?
  createdBy   String
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course?   @relation(fields: [courseId], references: [id])

  @@index([date])
  @@index([courseId])
  @@map("calendar_events")
}

model CareerReadinessScore {
  id              String   @id @default(cuid())
  studentId       String
  communication   Int
  accuracy        Int
  speed           Int
  reliability     Int
  technicalSkills Int
  professionalism Int
  overallScore    Int
  aiSummary       String   @db.Text
  evaluatedAt     DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("career_readiness_scores")
}

model SimulationSession {
  id               String   @id @default(cuid())
  studentId        String
  scenario         String
  courseSlug        String
  messages         Json     @default("[]")
  status           String   @default("active")
  communicationScore Int?
  problemSolvingScore Int?
  professionalismScore Int?
  overallScore     Int?
  aiFeedback       String?  @db.Text
  createdAt        DateTime @default(now())
  completedAt      DateTime?
  student          Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("simulation_sessions")
}

model InterviewSession {
  id                   String    @id @default(cuid())
  studentId            String
  role                 String
  courseSlug            String
  questions            Json      @default("[]")
  status               String    @default("active")
  overallScore         Int?
  communicationScore   Int?
  knowledgeScore       Int?
  problemSolvingScore  Int?
  professionalismScore Int?
  aiFeedback           String?   @db.Text
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
  student              Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("interview_sessions")
}

model JobPosting {
  id             String      @id @default(cuid())
  title          String
  company        String
  description    String      @db.Text
  requirements   String[]
  skills         String[]
  courseSlug      String?
  location       String
  type           String
  salaryRange    String?
  industry       String?
  isActive       Boolean     @default(true)
  isInternship   Boolean     @default(false)
  externalId     String?
  externalSource String?
  externalUrl    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  matches        JobMatch[]
  applications   JobApplication[]

  @@unique([externalId, externalSource])
  @@index([isActive])
  @@index([courseSlug])
  @@index([externalSource])
  @@map("job_postings")
}

model JobMatch {
  id           String     @id @default(cuid())
  studentId    String
  jobPostingId String
  matchScore   Int
  aiReasoning  String     @db.Text
  matchedAt    DateTime   @default(now())
  student      Student    @relation(fields: [studentId], references: [id])
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id])

  @@unique([studentId, jobPostingId])
  @@index([studentId])
  @@index([jobPostingId])
  @@map("job_matches")
}

model Testimonial {
  id           String   @id @default(cuid())
  name         String
  role         String
  company      String
  content      String   @db.Text
  rating       Int      @default(5)
  avatarUrl    String?
  isPublished  Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("testimonials")
}

model Trainer {
  id                   String          @id @default(cuid())
  name                 String
  email                String          @unique
  passwordHash         String?
  phone                String?
  bio                  String?         @db.Text
  photoUrl             String?         @db.Text
  specializations      String[]
  tier                 TrainerTier     @default(BASIC)
  credentials          String?         @db.Text
  certifications       String[]
  industryExperience   String?         @db.Text
  yearsOfExperience    Int             @default(0)
  studentsTrainedCount Int             @default(0)
  successRate          Decimal?        @db.Decimal(5, 2)
  averageRating        Decimal?        @db.Decimal(3, 2)
  totalRatings         Int             @default(0)
  accessGranted        Boolean         @default(false)
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  courses              CourseTrainer[]
  mentorshipRequests   MentorshipRequest[]
  ratings              TrainerRating[]
  enrollments          Enrollment[]
  students             Student[]
  schedules            Schedule[]
  availability         TrainerAvailability[]

  @@index([isActive])
  @@index([tier])
  @@map("trainers")
}

model TrainerAvailability {
  id         String   @id @default(cuid())
  trainerId  String
  dayOfWeek  Int      // 0=Sun, 1=Mon, ..., 6=Sat
  startTime  String   // "HH:MM" 24-hour format
  endTime    String   // "HH:MM" 24-hour format
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  trainer    Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, dayOfWeek, startTime])
  @@index([trainerId])
  @@map("trainer_availability")
}

model TrainerRating {
  id        String   @id @default(cuid())
  trainerId String
  studentId String
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trainer   Trainer  @relation(fields: [trainerId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([trainerId, studentId])
  @@index([trainerId])
  @@map("trainer_ratings")
}

model CourseTrainer {
  id         String   @id @default(cuid())
  courseId    String
  trainerId  String
  role       String   @default("instructor")
  assignedAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id])
  trainer    Trainer  @relation(fields: [trainerId], references: [id])

  @@unique([courseId, trainerId])
  @@map("course_trainers")
}

model CourseResource {
  id        String   @id @default(cuid())
  courseId   String
  lessonId   String?
  title      String
  type       String
  filePath   String
  fileName   String
  fileSize   Int
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id])
  lesson     Lesson?  @relation(fields: [lessonId], references: [id])

  @@index([courseId])
  @@map("course_resources")
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum SkillType {
  COMMUNICATION
  TECHNICAL
  TIME_MANAGEMENT
  PROBLEM_SOLVING
  PROFESSIONALISM
  ACCURACY
  TOOL_PROFICIENCY
  CLIENT_MANAGEMENT
}

enum FeedbackCategory {
  COMMUNICATION
  TECHNICAL_SKILLS
  PROFESSIONALISM
  RELIABILITY
  PROBLEM_SOLVING
  OVERALL
}

enum MentorshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

model EmployerFeedback {
  id           String           @id @default(cuid())
  studentId    String
  reviewerName String
  reviewerRole String
  category     FeedbackCategory
  rating       Int
  feedback     String           @db.Text
  createdAt    DateTime         @default(now())
  student      Student          @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("employer_feedback")
}

model MentorshipRequest {
  id        String           @id @default(cuid())
  studentId String
  trainerId String
  status    MentorshipStatus @default(PENDING)
  message   String           @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  student   Student          @relation(fields: [studentId], references: [id])
  trainer   Trainer          @relation(fields: [trainerId], references: [id])

  @@index([studentId])
  @@index([trainerId])
  @@map("mentorship_requests")
}

model EmailPracticeSession {
  id                    String   @id @default(cuid())
  studentId             String
  courseSlug             String
  scenarioType          String
  scenarioPrompt        String   @db.Text
  senderRole            String
  recipientRole         String
  studentEmail          String?  @db.Text
  toneScore             Int?
  clarityScore          Int?
  completenessScore     Int?
  grammarScore          Int?
  industryLanguageScore Int?
  overallScore          Int?
  aiFeedback            String?  @db.Text
  suggestedVersion      String?  @db.Text
  strengths             Json?
  improvements          Json?
  status                String   @default("pending")
  createdAt             DateTime @default(now())
  evaluatedAt           DateTime?
  student               Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("email_practice_sessions")
}

model JobApplication {
  id           String            @id @default(cuid())
  studentId    String
  jobPostingId String
  coverLetter  String            @db.Text
  status       ApplicationStatus @default(PENDING)
  adminNotes   String?           @db.Text
  appliedAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  student      Student           @relation(fields: [studentId], references: [id])
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobPostingId])
  @@index([studentId])
  @@index([jobPostingId])
  @@index([status])
  @@map("job_applications")
}

model VerifiedSkill {
  id         String    @id @default(cuid())
  studentId  String
  skillType  SkillType
  level      Int
  evidence   String    @db.Text
  verifiedAt DateTime  @default(now())
  student    Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, skillType])
  @@index([studentId])
  @@map("verified_skills")
}

model Subscription {
  id              String             @id @default(cuid())
  studentId       String
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(PENDING)
  amount          Decimal            @db.Decimal(10, 2)
  paymentMethod   String?
  paymentProof    String?
  referenceNumber String?
  startDate       DateTime?
  endDate         DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime           @default(now())
  student         Student            @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("subscriptions")
}

model PlatformSettings {
  id        String   @id(map: "platform_settings_pk") @default("singleton")
  siteName  String   @default("HUMI Training Center")
  timezone  String   @default("Asia/Manila")
  currency  String   @default("PHP")
  language  String   @default("en")
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model Waitlist {
  id           String         @id @default(cuid())
  scheduleId   String
  enrollmentId String
  position     Int
  status       WaitlistStatus @default(WAITING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  schedule     Schedule       @relation(fields: [scheduleId], references: [id])
  enrollment   Enrollment     @relation(fields: [enrollmentId], references: [id])

  @@unique([scheduleId, enrollmentId])
  @@index([scheduleId, status])
  @@index([enrollmentId])
  @@map("waitlist")
}

model SessionAttendance {
  id          String   @id @default(cuid())
  scheduleId  String
  studentId   String
  sessionDate DateTime @db.Date
  present     Boolean  @default(false)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  schedule    Schedule @relation(fields: [scheduleId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@unique([scheduleId, studentId, sessionDate])
  @@index([scheduleId, sessionDate])
  @@index([studentId])
  @@map("session_attendances")
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  email       String    @unique
  industry    String?
  logoUrl     String?
  maxSeats    Int       @default(10)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  managers    CorporateManager[]
  enrollments Enrollment[]
  students    Student[]

  @@map("organizations")
}

model CorporateManager {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  email           String       @unique
  passwordHash    String
  name            String
  role            String       @default("manager")
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@map("corporate_managers")
}

// ============================================================
// Communications Module
// ============================================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  ENROLLMENT
  PAYMENT
  TECHNICAL_SUPPORT
  COURSE_CONTENT
  CERTIFICATION
  CORPORATE_TRAINING
}

enum ActorType {
  ADMIN
  STUDENT
  TRAINER
  CORPORATE_MANAGER
}

enum ConversationType {
  DIRECT
  COURSE_GROUP
  ANNOUNCEMENT
  LESSON_DISCUSSION
}

enum NotificationType {
  NEW_MESSAGE
  TICKET_RESPONSE
  TRAINER_ANNOUNCEMENT
  LESSON_UPDATE
  JOB_ALERT
  COURSE_UPDATE
  SYSTEM
}

enum KBCategory {
  GETTING_STARTED
  COURSE_ENROLLMENT
  PAYMENT_GUIDE
  CERTIFICATION_GUIDE
  CORPORATE_TRAINING_GUIDE
  TECHNICAL_TROUBLESHOOTING
}

model SupportTicket {
  id            String         @id @default(cuid())
  referenceNo   String         @unique
  category      TicketCategory
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(OPEN)
  subject       String
  description   String         @db.Text
  submitterType ActorType
  submitterId   String
  assignedToId  String?
  resolvedAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  responses     TicketResponse[]

  @@index([status])
  @@index([submitterType, submitterId])
  @@index([assignedToId])
  @@index([referenceNo])
  @@index([category])
  @@index([createdAt])
  @@map("support_tickets")
}

model TicketResponse {
  id         String        @id @default(cuid())
  ticketId   String
  authorType ActorType
  authorId   String
  content    String        @db.Text
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_responses")
}

model Conversation {
  id          String               @id @default(cuid())
  type        ConversationType
  title       String?
  courseId     String?
  lessonId    String?
  createdByType ActorType
  createdById   String
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  participants ConversationParticipant[]
  messages     DirectMessage[]

  @@index([type])
  @@index([courseId])
  @@index([lessonId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  actorType      ActorType
  actorId        String
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, actorType, actorId])
  @@index([actorType, actorId])
  @@map("conversation_participants")
}

model DirectMessage {
  id             String        @id @default(cuid())
  conversationId String
  senderType     ActorType
  senderId       String
  content        String        @db.Text
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reads          MessageRead[]

  @@index([conversationId, createdAt])
  @@index([senderType, senderId])
  @@map("direct_messages")
}

model MessageRead {
  id        String       @id @default(cuid())
  messageId String
  actorType ActorType
  actorId   String
  readAt    DateTime     @default(now())
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, actorType, actorId])
  @@index([messageId])
  @@index([actorType, actorId])
  @@map("message_reads")
}

model Notification {
  id            String           @id @default(cuid())
  recipientType ActorType
  recipientId   String
  type          NotificationType
  title         String
  message       String
  linkUrl       String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  @@index([recipientType, recipientId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model KnowledgeBaseArticle {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  content     String     @db.Text
  category    KBCategory
  isPublished Boolean    @default(false)
  order       Int        @default(0)
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([category, isPublished])
  @@index([slug])
  @@map("knowledge_base_articles")
}

// ─── Settings Models (single-row, id = "singleton") ──────────────────────────

model EmailSettings {
  id                  String   @id(map: "email_settings_pk") @default("singleton")
  smtpHost            String   @default("smtp.gmail.com")
  smtpPort            Int      @default(587)
  smtpUser            String   @default("")
  smtpPassword        String   @default("")
  fromName            String   @default("HUMI Training Center")
  fromEmail           String   @default("")
  enrollmentEmails    Boolean  @default(true)
  lessonEmails        Boolean  @default(true)
  announcementEmails  Boolean  @default(true)
  certificationEmails Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  @@map("email_settings")
}

model SecuritySettings {
  id                 String   @id(map: "security_settings_pk") @default("singleton")
  passwordMinLength  Int      @default(8)
  requireUppercase   Boolean  @default(true)
  requireNumbers     Boolean  @default(true)
  requireSymbols     Boolean  @default(false)
  sessionTimeoutMins Int      @default(60)
  maxLoginAttempts   Int      @default(5)
  updatedAt          DateTime @updatedAt

  @@map("security_settings")
}

model BrandingSettings {
  id             String   @id(map: "branding_settings_pk") @default("singleton")
  logoUrl        String   @default("")
  faviconUrl     String   @default("")
  primaryColor   String   @default("#1d4ed8")
  secondaryColor String   @default("#7c3aed")
  bannerImageUrl String   @default("")
  bannerTagline  String   @default("Your Path to a VA Career")
  updatedAt      DateTime @updatedAt

  @@map("branding_settings")
}
