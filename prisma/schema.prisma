enum EmployerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Employer {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  companyName  String
  website      String?
  logoUrl      String?
  description  String?        @db.Text
  industry     String?
  location     String?
  status       EmployerStatus @default(PENDING)
  jobPostings  EmployerJobPosting[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

