enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  ENROLLMENT
  PAYMENT
  TECHNICAL_SUPPORT
  COURSE_CONTENT
  CERTIFICATION
  CORPORATE_TRAINING
}

enum ActorType {
  ADMIN
  HUMI_ADMIN
  STUDENT
  TRAINER
  CORPORATE_MANAGER
}

enum ConversationType {
  DIRECT
  COURSE_GROUP
  ANNOUNCEMENT
  LESSON_DISCUSSION
}

enum NotificationType {
  NEW_MESSAGE
  TICKET_RESPONSE
  TRAINER_ANNOUNCEMENT
  LESSON_UPDATE
  JOB_ALERT
  COURSE_UPDATE
  SYSTEM
  ASSIGNMENT_SUBMITTED
  ASSIGNMENT_GRADED
  ASSIGNMENT_DUE_SOON
  CONTACT_MESSAGE
}

enum KBCategory {
  GETTING_STARTED
  COURSE_ENROLLMENT
  PAYMENT_GUIDE
  CERTIFICATION_GUIDE
  CORPORATE_TRAINING_GUIDE
  TECHNICAL_TROUBLESHOOTING
}

model SupportTicket {
  id            String         @id @default(cuid())
  referenceNo   String         @unique
  category      TicketCategory
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(OPEN)
  subject       String
  description   String         @db.Text
  submitterType ActorType
  submitterId   String
  assignedToId  String?
  slaDeadline   DateTime?
  resolvedAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  responses     TicketResponse[]

  @@index([status])
  @@index([submitterType, submitterId])
  @@index([assignedToId])
  @@index([referenceNo])
  @@index([category])
  @@index([createdAt])
  @@index([slaDeadline])
  @@map("support_tickets")
}

model TicketResponse {
  id          String        @id @default(cuid())
  ticketId    String
  authorType  ActorType
  authorId    String
  content     String        @db.Text
  isInternal  Boolean       @default(false)
  attachments Json?
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_responses")
}

model Conversation {
  id            String               @id @default(cuid())
  type          ConversationType
  title         String?
  tenantId      String?
  courseId      String?
  lessonId      String?
  createdByType ActorType
  createdById   String
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenant        Organization?        @relation(fields: [tenantId], references: [id])
  participants  ConversationParticipant[]
  messages      DirectMessage[]

  @@index([tenantId])
  @@index([type])
  @@index([courseId])
  @@index([lessonId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  actorType      ActorType
  actorId        String
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, actorType, actorId])
  @@index([actorType, actorId])
  @@map("conversation_participants")
}

model DirectMessage {
  id             String        @id @default(cuid())
  conversationId String
  senderType     ActorType
  senderId       String
  content        String        @db.Text
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reads          MessageRead[]
  deletions      MessageDeletion[]

  @@index([conversationId, createdAt])
  @@index([senderType, senderId])
  @@map("direct_messages")
}

model MessageRead {
  id        String       @id @default(cuid())
  messageId String
  actorType ActorType
  actorId   String
  readAt    DateTime     @default(now())
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, actorType, actorId])
  @@index([messageId])
  @@index([actorType, actorId])
  @@map("message_reads")
}

model MessageDeletion {
  id         String        @id @default(cuid())
  messageId  String
  actorType  ActorType
  actorId    String
  deletedAt  DateTime      @default(now())
  message    DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, actorType, actorId])
  @@index([messageId])
  @@index([actorType, actorId])
  @@map("message_deletions")
}

model MessageContact {
  id            String    @id @default(cuid())
  ownerType     ActorType
  ownerId       String
  contactType   ActorType
  contactId     String
  contactName   String?
  tenantId      String?
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@unique([ownerType, ownerId, contactType, contactId])
  @@index([ownerType, ownerId])
  @@index([tenantId])
  @@map("message_contacts")
}

model Notification {
  id            String           @id @default(cuid())
  tenantId      String?
  recipientType ActorType
  recipientId   String
  type          NotificationType
  title         String
  message       String
  linkUrl       String?
