}

model ItAssetCategory {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  depreciationYears Int      @default(5)
  createdAt         DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets       ItAsset[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("it_asset_categories")
}

model ItAsset {
  id               String           @id @default(cuid())
  organizationId   String
  assetTag         String           @unique
  assetName        String
  categoryId       String?
  brand            String?
  model            String?
  serialNumber     String?
  specs            Json?

  purchaseDate     DateTime?
  purchaseCost     Decimal?         @db.Decimal(12, 2)
  supplier         String?

  warrantyStart    DateTime?
  warrantyEnd      DateTime?

  status           ItAssetStatus    @default(AVAILABLE)
  condition        ItAssetCondition @default(NEW)

  assignedToId     String?
  assignedDate     DateTime?

  location         String?

  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category         ItAssetCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assignedTo       HrEmployee?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  historyLogs      ItAssetHistoryLog[]
  maintenanceRecords ItMaintenanceRecord[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([assignedToId])
  @@map("it_assets")
}

model ItAssetHistoryLog {
  id              String   @id @default(cuid())
  assetId         String
  action          String
  previousStatus  String?
  newStatus       String?
  assignedToId    String?
  performedById   String?
  remarks         String?  @db.Text
  createdAt       DateTime @default(now())

  asset           ItAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedTo      HrEmployee? @relation("itHistoryAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  performedBy     HrEmployee? @relation("itHistoryPerformer", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@map("it_asset_history_logs")
}

model ItMaintenanceRecord {
  id               String              @id @default(cuid())
  assetId          String
  issueDescription String              @db.Text
  reportedDate     DateTime            @default(now())
  resolvedDate     DateTime?
  status           ItMaintenanceStatus @default(PENDING)
  cost             Decimal?            @db.Decimal(12, 2)
  vendor           String?
  notes            String?             @db.Text
  createdAt        DateTime            @default(now())

  asset            ItAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("it_maintenance_records")
}
