/* ------------------------------------------------------------------ */
/*  Payroll Runs                                                        */
/* ------------------------------------------------------------------ */

model HrPayrollRun {
  id             String          @id @default(cuid())
  organizationId String
  runNumber      String          @db.VarChar(30)
  periodStart    DateTime        @db.Date
  periodEnd      DateTime        @db.Date
  payDate        DateTime?       @db.Date
  status         HrPayrollStatus @default(DRAFT)
  totalGross     Decimal         @default(0) @db.Decimal(15, 2)
  totalDeductions Decimal        @default(0) @db.Decimal(15, 2)
  totalNet       Decimal         @default(0) @db.Decimal(15, 2)
  notes          String?         @db.Text
  approvedById   String?
  approvedAt     DateTime?
  paidById       String?
  paidAt         DateTime?
  createdById    String?
