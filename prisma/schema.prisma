/* ------------------------------------------------------------------ */
/*  Payroll Lines (per employee per run)                                */
/* ------------------------------------------------------------------ */

model HrPayrollLine {
  id              String  @id @default(cuid())
  payrollRunId    String
  employeeId      String
  basicSalary     Decimal @default(0) @db.Decimal(15, 2)
  daysWorked      Decimal @default(0) @db.Decimal(5, 2)
  absentDays      Decimal @default(0) @db.Decimal(5, 2)
  lateMins        Decimal @default(0) @db.Decimal(7, 2)
  // Holiday fields (DOLE)
  regHolidayDays  Decimal @default(0) @db.Decimal(5, 2)  // regular holidays worked (200%)
  specHolidayDays Decimal @default(0) @db.Decimal(5, 2)  // special non-working holidays worked (130%)
  holidayPay      Decimal @default(0) @db.Decimal(15, 2) // extra pay from holiday premiums
  // Overtime
  overtimeHours   Decimal @default(0) @db.Decimal(5, 2)
  overtimePay     Decimal @default(0) @db.Decimal(15, 2)
  // Night differential
  nightDiffHours  Decimal @default(0) @db.Decimal(5, 2)
  nightDiffPay    Decimal @default(0) @db.Decimal(15, 2)
  // Other earnings
  allowances      Decimal @default(0) @db.Decimal(15, 2)
  grossPay        Decimal @default(0) @db.Decimal(15, 2)
  // Deductions
  absenceDeduction Decimal @default(0) @db.Decimal(15, 2)
  lateDeduction   Decimal @default(0) @db.Decimal(15, 2)
  sssEmployee     Decimal @default(0) @db.Decimal(15, 2)
  sssEmployer     Decimal @default(0) @db.Decimal(15, 2)
  philhealthEmployee Decimal @default(0) @db.Decimal(15, 2)
  philhealthEmployer Decimal @default(0) @db.Decimal(15, 2)
  pagibigEmployee Decimal @default(0) @db.Decimal(15, 2)
  pagibigEmployer Decimal @default(0) @db.Decimal(15, 2)
  withholdingTax  Decimal @default(0) @db.Decimal(15, 2)
  otherDeductions Decimal @default(0) @db.Decimal(15, 2)
  totalDeductions Decimal @default(0) @db.Decimal(15, 2)
  netPay          Decimal @default(0) @db.Decimal(15, 2)
  remarks         String? @db.VarChar(300)
  createdAt       DateTime @default(now())

  payrollRun HrPayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   HrEmployee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@map("hr_payroll_lines")
}

/* ------------------------------------------------------------------ */
