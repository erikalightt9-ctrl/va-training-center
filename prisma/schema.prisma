  updatedAt      DateTime       @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals        CrmDeal[]
  activities   CrmActivity[]

  @@index([organizationId, contactType])
  @@index([organizationId, name])
  @@map("crm_contacts")
}

model CrmDeal {
  id                String       @id @default(cuid())
  organizationId    String
  title             String       @db.VarChar(300)
  value             Decimal      @default(0) @db.Decimal(15, 2)
  currency          String       @default("PHP") @db.VarChar(3)
  stage             CrmDealStage @default(NEW_LEAD)
  probability       Int          @default(0)
  expectedCloseDate DateTime?    @db.Date
  contactId         String?
  invoiceId         String?      @unique
  notes             String?      @db.Text
  closedAt          DateTime?
  createdById       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      CrmContact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoice      AccInvoice?   @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  activities   CrmActivity[]
  tasks        CrmTask[]

  @@index([organizationId, stage])
  @@index([organizationId, contactId])
  @@index([organizationId, expectedCloseDate])
  @@map("crm_deals")
}

model CrmActivity {
  id             String          @id @default(cuid())
  organizationId String
  activityType   CrmActivityType
  subject        String          @db.VarChar(300)
  body           String?         @db.Text
  dealId         String?
  contactId      String?
  createdById    String?
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal         CrmDeal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact      CrmContact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([dealId])
  @@index([contactId])
  @@map("crm_activities")
}

model CrmTask {
  id             String    @id @default(cuid())
  organizationId String
  title          String    @db.VarChar(300)
  description    String?   @db.Text
  dueDate        DateTime? @db.Date
  isDone         Boolean   @default(false)
  dealId         String?
  assignedToId   String?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal         CrmDeal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId, isDone, dueDate])
  @@index([dealId])
  @@map("crm_tasks")
}

