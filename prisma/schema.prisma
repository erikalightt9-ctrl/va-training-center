  @@map("employer_job_postings")
}

enum HiringStage {
  APPLIED
  REVIEWED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model EmployerApplication {
  id             String              @id @default(cuid())
  jobPostingId   String
  studentId      String?
  applicantName  String
  applicantEmail String
  coverLetter    String              @db.Text
  resumeUrl      String?
  stage          HiringStage         @default(APPLIED)
  employerNotes  String?             @db.Text
  interviewDate  DateTime?
  zoomJoinUrl    String?
  jobPosting     EmployerJobPosting  @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  student        Student?            @relation(fields: [studentId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([jobPostingId])
  @@index([studentId])
  @@index([stage])
  @@map("employer_applications")
}

/* ------------------------------------------------------------------ */
/*  Trainer Tier Configuration                                          */
/* ------------------------------------------------------------------ */

model TrainerTierConfig {
  tier             TrainerTier @id
  label            String      @default("")
  upgradeFee       Decimal     @default(0)    @db.Decimal(10, 2)
  baseProgramPrice Decimal     @default(1500) @db.Decimal(10, 2)
  benefits         String[]
  maxCapacity      Int         @default(15)
  revenueSharePct  Int         @default(70)
  isActive         Boolean     @default(true)
  updatedAt        DateTime    @updatedAt

  @@map("trainer_tier_configs")
}

/* ------------------------------------------------------------------ */
/*  Revenue System                                                      */
/* ------------------------------------------------------------------ */

enum RevenueType {
  PLATFORM_FEE
  TENANT_SUBSCRIPTION
  ENROLLMENT_PAYMENT
  TRAINER_EARNING
  REFUND
  MANUAL
}

model RevenueRecord {
  id            String      @id @default(cuid())
  tenantId      String?
  userId        String?
  userType      String?
  type          RevenueType @default(MANUAL)
  amount        Decimal     @db.Decimal(12, 2)
  currency      String      @default("PHP")
  description   String?
  referenceId   String?
  referenceType String?
  status        String      @default("active")
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  auditLogs     RevenueAuditLog[]

  @@index([tenantId])
  @@index([userId, userType])
  @@index([createdAt])
  @@index([status])
  @@map("revenue_records")
}

model RevenueAuditLog {
  id         String        @id @default(cuid())
  recordId   String
  action     String
  actorId    String
  actorRole  String
  before     Json?
  after      Json?
  reason     String?
  createdAt  DateTime      @default(now())
  record     RevenueRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@index([actorId])
  @@map("revenue_audit_logs")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  actorId    String
  actorRole  String
  action     String
  entity     String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TenantPage {
  id             String      @id @default(cuid())
  organizationId String
  title          String
  slug           String
  type           PageType    @default(CUSTOM)
  isPublished    Boolean     @default(false)
  sections       Json        @default("[]")
  metaTitle      String?
  metaDescription String?
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, isPublished])
  @@map("tenant_pages")
}

model TenantTheme {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  primaryColor    String       @default("#3B82F6")
  secondaryColor  String       @default("#1E40AF")
  accentColor     String       @default("#F59E0B")
  backgroundColor String       @default("#FFFFFF")
  textColor       String       @default("#111827")
  fontHeading     String       @default("Inter")
  fontBody        String       @default("Inter")
  logoUrl         String?
  faviconUrl      String?
  customCss       String?      @db.Text
  headingSize     String       @default("md")
  bodySize        String       @default("md")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tenant_themes")
}

/* ------------------------------------------------------------------ */
/*  Organization Tasks                                                 */
/* ------------------------------------------------------------------ */

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model OrganizationTask {
  id             String       @id @default(cuid())
  organizationId String
  title          String       @db.VarChar(200)
  description    String?      @db.Text
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  assigneeName   String?      @db.VarChar(100)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@map("organization_tasks")
}

/* ------------------------------------------------------------------ */
/*  Organization Files                                                 */
/* ------------------------------------------------------------------ */

model OrganizationFile {
  id             String       @id @default(cuid())
  organizationId String
  name           String       @db.VarChar(255)
  size           Int
  mimeType       String       @db.VarChar(100)
  url            String
  uploadedBy     String?      @db.VarChar(100)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("organization_files")
}

/* ------------------------------------------------------------------ */
/*  Training Tiers                                                     */
/* ------------------------------------------------------------------ */

model TrainingTier {
  id          String   @id @default(cuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String?  @db.Text
  features    String[]
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("training_tiers")
}

/* ------------------------------------------------------------------ */
/*  Tenant Invites                                                     */
/* ------------------------------------------------------------------ */

model TenantInvite {
  id           String       @id @default(cuid())
  code         String       @unique @default(cuid())
  tenantId     String
  email        String?      // optional: lock invite to specific email
  role         String       @default("student") // student | corporate | trainer
  expiresAt    DateTime
  usedAt       DateTime?
  usedByEmail  String?
  createdAt    DateTime     @default(now())
  tenant       Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([code])
  @@map("tenant_invites")
}
