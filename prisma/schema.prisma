generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EnrollmentStatus {
  PENDING
  PAYMENT_SUBMITTED
  PAYMENT_VERIFIED
  EMAIL_VERIFIED
  APPROVED
  REJECTED
  ENROLLED
}

enum EmploymentStatus {
  EMPLOYED_FULL_TIME
  EMPLOYED_PART_TIME
  SELF_EMPLOYED
  UNEMPLOYED
  STUDENT
  FREELANCER
}

enum ToolFamiliarity {
  QUICKBOOKS
  CRM
  EHR
  MICROSOFT_OFFICE
  GOOGLE_WORKSPACE
  SLACK
  ZOOM
  TRELLO
  ASANA
  SALESFORCE
  HUBSPOT
  OTHER
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

enum SubmissionStatus {
  PENDING
  GRADED
  RETURNED
}

enum PaymentStatus {
  PENDING_PAYMENT
  PAID
  FAILED
  REFUNDED
}

enum EventType {
  ANNOUNCEMENT
  DEADLINE
  ORIENTATION
  HOLIDAY
  CUSTOM
  CLASS
  MEETING
}

enum BadgeType {
  FIRST_LESSON
  QUIZ_MASTER
  COURSE_COMPLETER
  TOP_CONTRIBUTOR
  ASSIGNMENT_STAR
  FORUM_STARTER
}

enum StudentPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum SubscriptionPlan {
  MONTHLY
  QUARTERLY
  LIFETIME
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELLED
}

enum ScheduleStatus {
  OPEN
  CLOSED
  FULL
  COMPLETED
}

enum TrainerTier {
  BASIC
  PROFESSIONAL
  PREMIUM
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
}

enum CourseTier {
  BASIC
  PROFESSIONAL
  ADVANCED
}

enum SubmissionType {
  FILE_UPLOAD
  TEXT_RESPONSE
  EXTERNAL_LINK
  TASK_COMPLETION
}

enum TenantPlan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum PageType {
  LANDING
  CONTACT
  CUSTOM
}

enum SectionType {
  HERO
  FEATURES
  TESTIMONIALS
  CONTACT
  CTA
  TEXT
  IMAGE
}

model Course {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  description   String       @db.Text
  durationWeeks Int
  price         Decimal      @db.Decimal(10, 2)
  priceBasic        Decimal  @default(0) @db.Decimal(10, 2)
  priceProfessional Decimal  @default(0) @db.Decimal(10, 2)
  priceAdvanced     Decimal  @default(0) @db.Decimal(10, 2)
  currency      String       @default("PHP")
  outcomes      String[]
  isActive      Boolean      @default(true)
  deletedAt     DateTime?
  featuresBasic        String[]
  featuresProfessional String[]
  featuresAdvanced     String[]
  popularTier   String?
  industry      String?
  tenantId      String?
  discountBasic        Json?
  discountProfessional Json?
  discountAdvanced     Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant          Organization?  @relation(fields: [tenantId], references: [id])
  enrollments     Enrollment[]
  courseProgress  CourseProgress[]
  modules         Module[]
  lessons         Lesson[]
  quizzes         Quiz[]
  certificates    Certificate[]
  threads         ForumThread[]
  assignments     Assignment[]
  calendarEvents   CalendarEvent[]
  schedules        Schedule[]
  trainers         CourseTrainer[]
  resources        CourseResource[]
  usageSnapshots   CourseUsageSnapshot[]
  priceHistory     CoursePriceHistory[]
  attendanceRecords AttendanceRecord[]

  @@index([tenantId])
  @@map("courses")
}

model CoursePriceHistory {
  id        String   @id @default(cuid())
  courseId  String
  tier      String
  oldPrice  Decimal  @db.Decimal(10, 2)
  newPrice  Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @default(now()) @db.Timestamptz
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_price_history")
}

model CourseUsageSnapshot {
  id             String        @id @default(cuid())
  courseId       String
  tenantId       String?
  snapshotDate   DateTime      @db.Date
  totalEnrolled  Int           @default(0)
  activeStudents Int           @default(0)
  completions    Int           @default(0)
  avgProgress    Int           @default(0)
  lessonViews    Int           @default(0)
  course         Course        @relation(fields: [courseId], references: [id])

  @@unique([courseId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@map("course_usage_snapshots")
}

model Module {
  id          String       @id @default(cuid())
  courseId    String
  title       String
  description String?      @db.Text
  order       Int          @default(0)
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  course      Course       @relation(fields: [courseId], references: [id])
  lessons     Lesson[]
  assignments Assignment[]

  @@index([courseId, order])
  @@map("modules")
}

model Enrollment {
  id                    String            @id @default(cuid())
  status                EnrollmentStatus  @default(PENDING)
  paymentStatus         PaymentStatus     @default(PENDING_PAYMENT)
  fullName              String
  dateOfBirth           DateTime          @db.Date
  email                 String
  contactNumber         String
  address               String            @db.Text
  educationalBackground String            @db.Text
  workExperience        String            @db.Text
  employmentStatus      EmploymentStatus
  technicalSkills       String[]
  toolsFamiliarity      ToolFamiliarity[]
  whyEnroll             String            @db.Text
  courseId              String
  course                Course            @relation(fields: [courseId], references: [id])
  trainerId             String?
  trainer               Trainer?          @relation(fields: [trainerId], references: [id])
  courseTier            CourseTier        @default(BASIC)
  trainerTier           TrainerTier?
  baseProgramPrice      Decimal?          @db.Decimal(10, 2)
  trainerUpgradeFee     Decimal?          @db.Decimal(10, 2)
  scheduleId            String?
  schedule              Schedule?         @relation(fields: [scheduleId], references: [id])
  ipAddress             String?
  emailConfirmedAt         DateTime?
  emailVerificationToken   String?           @unique
  emailTokenExpiresAt      DateTime?
  activationToken          String?           @unique
  activationTokenExpiresAt DateTime?
  statusUpdatedAt          DateTime?
  statusUpdatedBy          String?
  referenceCode            String?           @unique
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  organizationId           String?
  organization             Organization? @relation(fields: [organizationId], references: [id])
  student                  Student?
  payments                 Payment[]
  waitlistEntries          Waitlist[]

  @@index([status])
  @@index([courseId])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([email])
  @@index([trainerId])
  @@index([scheduleId])
  @@index([referenceCode])
  @@index([organizationId])
  @@map("enrollments")
}

model Payment {
  id              String        @id @default(cuid())
  enrollmentId    String
  amount          Decimal       @db.Decimal(10, 2)
  method          String
  status          PaymentStatus @default(PENDING_PAYMENT)
  proofFilePath   String?
  proofFileName   String?
  referenceNumber String?
  notes           String?       @db.Text
  verifiedBy      String?
  verifiedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  enrollment      Enrollment    @relation(fields: [enrollmentId], references: [id])

  @@index([enrollmentId])
  @@index([status])
  @@map("payments")
}

model Admin {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  name                  String
  isSuperAdmin          Boolean   @default(true)
  failedAttempts        Int       @default(0)
  lockUntil             DateTime?
  resetToken            String?   @unique
  resetTokenExpiresAt   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("admins")
}

model HumiAdmin {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  name                  String
  isActive              Boolean   @default(true)
  failedAttempts        Int       @default(0)
  lockUntil             DateTime?
  mustChangePassword    Boolean   @default(true)
  resetToken            String?   @unique
  resetTokenExpiresAt   DateTime?
  // Feature-based permissions (principle of least privilege — all false by default)
  canReviewTenants      Boolean   @default(false)
  canOnboardTenants     Boolean   @default(false)
  canMonitorPlatform    Boolean   @default(false)
  canProvideSupport     Boolean   @default(false)
  canManageContent      Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([email])
  @@map("humi_admins")
}

model Student {
  id                 String               @id @default(cuid())
  enrollmentId       String               @unique
  email              String               @unique
  passwordHash       String
  name               String
  bio                String?              @db.Text
  avatarUrl          String?
  mustChangePassword    Boolean              @default(true)
  failedAttempts        Int                  @default(0)
  lockUntil             DateTime?
  resetToken            String?              @unique
  resetTokenExpiresAt   DateTime?
  batch              String?
  scheduleId         String?
  paymentStatus      StudentPaymentStatus @default(UNPAID)
  amountPaid         Decimal              @default(0) @db.Decimal(10, 2)
  accessGranted      Boolean              @default(false)
  accessExpiry       DateTime?
  notes              String?              @db.Text
  courseTier         CourseTier           @default(BASIC)
  trainerId          String?
  organizationId     String?
  portfolioPublic    Boolean              @default(false)
  createdAt          DateTime             @default(now())
  enrollment   Enrollment         @relation(fields: [enrollmentId], references: [id])
  schedule     Schedule?          @relation(fields: [scheduleId], references: [id])
  trainer      Trainer?           @relation(fields: [trainerId], references: [id])
  organization Organization?     @relation(fields: [organizationId], references: [id])
  completions     LessonCompletion[]
  courseProgress  CourseProgress[]
  attempts        QuizAttempt[]
  certificates Certificate[]
  threads      ForumThread[]
  posts        ForumPost[]
  submissions  Submission[]
  badges       StudentBadge[]
  points       PointTransaction[]
  attendance   AttendanceRecord[]
  careerScores   CareerReadinessScore[]
  simulations    SimulationSession[]
  interviews     InterviewSession[]
  jobMatches     JobMatch[]
  employerFeedback  EmployerFeedback[]
  mentorshipRequests MentorshipRequest[]
  emailPracticeSessions EmailPracticeSession[]
  jobApplications       JobApplication[]
  placement             Placement?
  verifiedSkills        VerifiedSkill[]
  subscriptions         Subscription[]
  trainerRatings        TrainerRating[]
  sessionAttendances    SessionAttendance[]
  placementResumes      PlacementResume[]
  coachingSessions      CoachingSession[]
  employerApplications  EmployerApplication[]

  @@index([email])
  @@index([trainerId])
  @@index([paymentStatus])
  @@index([accessGranted])
  @@index([scheduleId])
  @@index([organizationId])
  @@map("students")
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  moduleId    String?
  title       String
  content     String   @db.Text
  order       Int
  durationMin Int      @default(0)
  isPublished   Boolean  @default(false)
  isFreePreview Boolean  @default(false)
  tier          CourseTier @default(BASIC)
  videoUrl      String?
  createdAt     DateTime @default(now())
  course      Course             @relation(fields: [courseId], references: [id])
  module      Module?            @relation(fields: [moduleId], references: [id])
  completions LessonCompletion[]
  resources   CourseResource[]
  assignments Assignment[]

  @@index([courseId, tier, order])
  @@map("lessons")
}

model LessonCompletion {
  id          String   @id @default(cuid())
  studentId   String
  lessonId    String
  completedAt DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([studentId, lessonId])
  @@map("lesson_completions")
}

model CourseProgress {
  id               String    @id @default(cuid())
  studentId        String
  courseId         String
  lessonsCompleted Int       @default(0)
  totalLessons     Int       @default(0)
  percentComplete  Int       @default(0)
  lastActiveAt     DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  student          Student   @relation(fields: [studentId], references: [id])
  course           Course    @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@index([courseId, completedAt])
  @@map("course_progress")
}

model Quiz {
  id           String         @id @default(cuid())
  courseId     String
  title        String
  description  String?
  passingScore Int            @default(70)
  isPublished  Boolean        @default(false)
  duration     Int?           // quiz duration in minutes; null = unlimited
  createdAt    DateTime       @default(now())
  course       Course         @relation(fields: [courseId], references: [id])
  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@index([courseId])
  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  type          QuestionType
  question      String
  options       String[]
  correctAnswer String
  points        Int          @default(10)
  order         Int
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       QuizAnswer[]

  @@index([quizId, order])
  @@map("quiz_questions")
}

model QuizAttempt {
  id            String       @id @default(cuid())
  studentId     String
  quizId        String
  score         Int          @default(0)
  passed        Boolean      @default(false)
  correct       Int          @default(0)
  total         Int          @default(0)
  completedAt   DateTime     @default(now())
  // Timer fields
  startTime     DateTime?
  endTime       DateTime?
  isSubmitted   Boolean      @default(false)
  // Anti-cheat
  violations    Int          @default(0)
  // Randomization: ordered question IDs for this attempt
  questionOrder String[]
  student       Student      @relation(fields: [studentId], references: [id])
  quiz          Quiz         @relation(fields: [quizId], references: [id])
  answers       QuizAnswer[]

  @@index([studentId, quizId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id         String       @id @default(cuid())
  attemptId  String
  questionId String
  answer     String
  isCorrect  Boolean
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   QuizQuestion @relation(fields: [questionId], references: [id])

  @@map("quiz_answers")
}

model Certificate {
  id         String   @id @default(cuid())
  studentId  String
  courseId   String
  issuedAt   DateTime @default(now())
  certNumber String   @unique @default(cuid())
  student    Student  @relation(fields: [studentId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("certificates")
}

model ForumThread {
  id        String      @id @default(cuid())
  courseId  String?
  studentId String
  title     String
  createdAt DateTime    @default(now())
  course    Course?     @relation(fields: [courseId], references: [id])
  student   Student     @relation(fields: [studentId], references: [id])
  posts     ForumPost[]

  @@index([courseId])
  @@map("forum_threads")
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  studentId String
  content   String      @db.Text
  parentId  String?
  createdAt DateTime    @default(now())
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  student   Student     @relation(fields: [studentId], references: [id])
  parent    ForumPost?  @relation("Replies", fields: [parentId], references: [id])
  replies   ForumPost[] @relation("Replies")

  @@index([threadId])
  @@map("forum_posts")
}

model Assignment {
  id                  String         @id @default(cuid())
  courseId            String
  lessonId            String?
  moduleId            String?
  title               String
  description         String?        @db.Text
  instructions        String         @db.Text
  submissionType      SubmissionType @default(FILE_UPLOAD)
  dueDate             DateTime?
  startDate           DateTime?
  maxPoints           Int            @default(100)
  passingScore        Int            @default(70)
  allowLateSubmission Boolean        @default(false)
  allowResubmission   Boolean        @default(false)
  maxFileSizeMB       Int            @default(10)
  allowedFileTypes    String[]       @default(["pdf", "docx", "xlsx", "jpg", "png"])
  rubric              Json?
  isPublished         Boolean        @default(false)
  isRequired          Boolean        @default(true)
  order               Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  course              Course         @relation(fields: [courseId], references: [id])
  lesson              Lesson?        @relation(fields: [lessonId], references: [id])
  module              Module?        @relation(fields: [moduleId], references: [id])
  submissions         Submission[]

  @@index([courseId])
  @@index([lessonId])
  @@index([moduleId])
  @@map("assignments")
}

model Submission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  filePath      String?
  fileName      String?
  fileSize      Int?
  textAnswer    String?          @db.Text
  linkUrl       String?
  taskCompleted Boolean?
  status        SubmissionStatus @default(PENDING)
  grade         Int?
  feedback      String?          @db.Text
  rubricScores  Json?
  gradedBy      String?
  aiEvaluation  Json?
  aiEvaluatedAt DateTime?
  submittedAt   DateTime         @default(now())
  gradedAt      DateTime?
  assignment    Assignment       @relation(fields: [assignmentId], references: [id])
  student       Student          @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("submissions")
}

model Badge {
  id          String        @id @default(cuid())
  type        BadgeType     @unique
  name        String
  description String
  icon        String
  students    StudentBadge[]

  @@map("badges")
}

model StudentBadge {
  id        String   @id @default(cuid())
  studentId String
  badgeId   String
  earnedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([studentId, badgeId])
  @@map("student_badges")
}

model PointTransaction {
  id        String   @id @default(cuid())
  studentId String
  points    Int
  reason    String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("point_transactions")
}

model AttendanceRecord {
  id              String    @id @default(cuid())
  studentId       String
  courseId        String?   // which course this check-in belongs to
  clockIn         DateTime  @default(now())
  clockOut        DateTime?
  durationMinutes Int?      // computed on clock-out: (clockOut - clockIn) in minutes
  createdAt       DateTime  @default(now())
  student         Student   @relation(fields: [studentId], references: [id])
  course          Course?   @relation(fields: [courseId], references: [id])

  @@index([studentId])
  @@index([clockIn])
  @@index([courseId])
  @@map("attendance_records")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model RateLimitAttempt {
  id        String   @id @default(cuid())
  ip        String
  endpoint  String
  createdAt DateTime @default(now())

  @@index([ip, endpoint, createdAt])
  @@map("rate_limit_attempts")
}

model Schedule {
  id                   String         @id @default(cuid())
  name                 String
  courseId              String
  trainerId            String?
  startDate            DateTime       @db.Date
  endDate              DateTime       @db.Date
  daysOfWeek           Int[]
  startTime            String
  endTime              String
  maxCapacity          Int            @default(25)
  enrollmentCutOffDays Int            @default(2)
  status               ScheduleStatus @default(OPEN)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  course               Course         @relation(fields: [courseId], references: [id])
  trainer              Trainer?       @relation(fields: [trainerId], references: [id])
  students             Student[]
  enrollments          Enrollment[]
  waitlist             Waitlist[]
  sessionAttendances   SessionAttendance[]

  @@index([courseId])
  @@index([trainerId])
  @@index([status])
  @@index([startDate])
  @@map("schedules")
}

model CalendarEvent {
  id             String    @id @default(cuid())
  title          String
  description    String?   @db.Text
  date           DateTime  @db.Date
  endDate        DateTime? @db.Date
  startTime      String?   // "HH:MM" 24-hour, e.g. "09:00"
  endTime        String?   // "HH:MM" 24-hour, e.g. "10:30"
  type           EventType @default(CUSTOM)
  courseId       String?
  assignedUserId String?   // user assigned to this event
  creatorRole    String?   // role of the creator: "admin" | "trainer"
  createdBy      String
  isPublished    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  course         Course?   @relation(fields: [courseId], references: [id])

  googleEventId  String?   // Google Calendar event ID after sync

  @@index([date])
  @@index([courseId])
  @@map("calendar_events")
}

model GoogleCalendarToken {
  id           String    @id @default(cuid())
  userId       String
  userRole     String    // "admin" | "trainer"
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  tokenType    String?
  expiresAt    DateTime?
  calendarId   String    @default("primary")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, userRole])
  @@map("google_calendar_tokens")
}

model CareerReadinessScore {
  id              String   @id @default(cuid())
  studentId       String
  communication   Int
  accuracy        Int
  speed           Int
  reliability     Int
  technicalSkills Int
  professionalism Int
  overallScore    Int
  aiSummary       String   @db.Text
  evaluatedAt     DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("career_readiness_scores")
}

model SimulationSession {
  id               String   @id @default(cuid())
  studentId        String
  scenario         String
  courseSlug        String
  messages         Json     @default("[]")
  status           String   @default("active")
  communicationScore Int?
  problemSolvingScore Int?
  professionalismScore Int?
  overallScore     Int?
  aiFeedback       String?  @db.Text
  createdAt        DateTime @default(now())
  completedAt      DateTime?
  student          Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("simulation_sessions")
}

model InterviewSession {
  id                   String    @id @default(cuid())
  studentId            String
  role                 String
  courseSlug            String
  questions            Json      @default("[]")
  status               String    @default("active")
  overallScore         Int?
  communicationScore   Int?
  knowledgeScore       Int?
  problemSolvingScore  Int?
  professionalismScore Int?
  aiFeedback           String?   @db.Text
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
  student              Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("interview_sessions")
}

model JobPosting {
  id             String      @id @default(cuid())
  title          String
  company        String
  description    String      @db.Text
  requirements   String[]
  skills         String[]
  courseSlug      String?
  location       String
  type           String
  salaryRange    String?
  industry       String?
  isActive       Boolean     @default(true)
  isInternship   Boolean     @default(false)
  externalId     String?
  externalSource String?
  externalUrl    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  matches        JobMatch[]
  applications   JobApplication[]

  @@unique([externalId, externalSource])
  @@index([isActive])
  @@index([courseSlug])
  @@index([externalSource])
  @@map("job_postings")
}

model JobMatch {
  id           String     @id @default(cuid())
  studentId    String
  jobPostingId String
  matchScore   Int
  aiReasoning  String     @db.Text
  matchedAt    DateTime   @default(now())
