enum HrEmploymentType {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  PART_TIME
  INTERN
}

enum HrEmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
  ON_LEAVE
}

enum HrPayrollStatus {
  DRAFT
  APPROVED
  PAID
  VOIDED
}

enum HrLeaveType {
  SICK
  VACATION
  EMERGENCY
  MATERNITY
  PATERNITY
  BEREAVEMENT
  OTHER
}

enum HrLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum HrPortalRole {
  EMPLOYEE
  DRIVER
  MANAGER
}

enum HrFuelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HrAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum CrmContactType {
  LEAD
  PROSPECT
  CUSTOMER
  PARTNER
}

enum CrmDealStage {
  NEW_LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
}

/* ------------------------------------------------------------------ */
/*  Employee 201 File                                                   */
/* ------------------------------------------------------------------ */

model HrEmployee {
  id               String            @id @default(cuid())
  organizationId   String
  employeeNumber   String            @db.VarChar(20)
  firstName        String            @db.VarChar(100)
  lastName         String            @db.VarChar(100)
  middleName       String?           @db.VarChar(100)
  email            String            @db.VarChar(200)
  phone            String?           @db.VarChar(30)
  position         String            @db.VarChar(150)
  department       String?           @db.VarChar(100)
  employmentType   HrEmploymentType  @default(REGULAR)
  status           HrEmployeeStatus  @default(ACTIVE)
  hireDate         DateTime          @db.Date
  regularizationDate DateTime?       @db.Date
  separationDate   DateTime?         @db.Date
  separationReason String?           @db.VarChar(300)
  // Government IDs (PH compliance)
  sssNumber        String?           @db.VarChar(20)
  philhealthNumber String?           @db.VarChar(20)
  pagibigNumber    String?           @db.VarChar(20)
  tinNumber        String?           @db.VarChar(20)
  // Payroll declared share defaults (saved per-employee to avoid re-entry each run)
  payrollSssEmployee        Decimal? @db.Decimal(10,2)
  payrollSssEmployer        Decimal? @db.Decimal(10,2)
  payrollPhilhealthEmployee Decimal? @db.Decimal(10,2)
  payrollPhilhealthEmployer Decimal? @db.Decimal(10,2)
  payrollPagibigEmployee    Decimal? @db.Decimal(10,2)
  payrollPagibigEmployer    Decimal? @db.Decimal(10,2)
  payrollWtaxOverride       Decimal? @db.Decimal(10,2)
  // Personal info
  birthDate        DateTime?         @db.Date
  gender           String?           @db.VarChar(10)
  civilStatus      String?           @db.VarChar(20)
  address          String?           @db.Text
  emergencyContact String?           @db.VarChar(150)
  emergencyPhone   String?           @db.VarChar(30)
  avatarUrl        String?
  // Employee portal auth
  passwordHash        String?
  mustChangePassword  Boolean       @default(true)
  failedAttempts      Int           @default(0)
  isPortalEnabled     Boolean       @default(false)
  portalRole          HrPortalRole  @default(EMPLOYEE)
  // Extended 201 fields
  nationality         String?       @db.VarChar(100)
  presentAddress      String?       @db.Text
  permanentAddress    String?       @db.Text
  allowance           Decimal?      @db.Decimal(10,2)
  payrollType         String?       @db.VarChar(20)
  remarks             String?       @db.Text
  lastWorkingDate     DateTime?     @db.Date
  emergencyRelationship String?     @db.VarChar(50)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts     HrEmployeeContract[]
  payrollLines  HrPayrollLine[]
  attendance    HrAttendanceLog[]
  leaveRequests HrLeaveRequest[]
  fuelRequests  HrFuelRequest[]
  documents     HrEmployeeDocument[]
  itAssets             ItAsset[]
  itHistoryAssignee    ItAssetHistoryLog[] @relation("itHistoryAssignee")
  itHistoryPerformer   ItAssetHistoryLog[] @relation("itHistoryPerformer")

  @@unique([organizationId, employeeNumber])
  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, department])
  @@map("hr_employees")
}

