  @@index([status])
  @@map("employers")
}

model EmployerJobPosting {
  id           String               @id @default(cuid())
  employerId   String
  title        String
  description  String               @db.Text
  requirements String[]
  skills       String[]
  location     String
  type         String               @default("Full-time")
