    "@hookform/resolvers": "^5.2.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.8",
    "@react-pdf/renderer": "^4.3.2",
    "@types/pg": "^8.16.0",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "googleapis": "^171.4.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "openai": "^6.25.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.19.0",
    "prisma": "^7.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
